# Database — PostgreSQL (Medusa requires Postgres, not MySQL)
DATABASE_URL=postgres://user:password@localhost:5432/fiorisce_medusa

# Redis (required for Medusa event bus and cache)
REDIS_URL=redis://localhost:6379

# Medusa secrets — generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here
COOKIE_SECRET=your-cookie-secret-here

# CORS — Next.js storefront and admin origins
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:7001
AUTH_CORS=http://localhost:3000

# Medusa backend URL (used by Next.js SDK)
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_PUBLISHABLE_KEY=your-publishable-api-key-here

# Midtrans payment gateway
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
